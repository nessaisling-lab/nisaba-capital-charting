# Rust build artifacts
/target/

# Environment variables — never commit secrets
.env

# IDE / editor
.vscode/
.idea/
*.iml

# OS
.DS_Store
Thumbs.db

# Logs
*.log
InstallationLog.txt

# Plugin / skill tooling (local, not project code)
.agents/
.claude/skills/
.qwen/
.vibe/
skills-lock.json

# Claude Code local settings (personal, not shared)
.claude/settings.local.json

# Generated design extraction output
design-extract-output/

# Video review scratch (frame extraction + audio for Whisper)
frames_v*/
audio.mp3
audio.wav
*.original.md
temp_*.txt

# Installer build output (large binaries; ship via release artifacts)
installer/Output/

# Inno Setup extras (logs + leftover binaries that aren't the final .exe)
installer/*.log
installer/*.exe.bak

# Environment variables — additional patterns (defense in depth)
.env.local
.env.*.local
.env.development
.env.production

# Office lock files (created when .pptx/.docx is open in Word/PowerPoint)
~$*.pptx
~$*.docx
~$*.xlsx

# Rust extras
*.rs.bk
.rust-analyzer/
rustc-ice-*.txt

# Python (scripts/ uses python-pptx — cache dirs appear on import)
__pycache__/
*.pyc

# OneDrive conflict files (Documents folder is OneDrive-redirected)
*-Conflict-*
* (*'s conflicted copy *)*

# Editor backups
*.swp
*.swo
*~

# Test coverage (if added later)
tarpaulin-report.html
*.profraw
*.profdata
lcov.info

# Local Postgres data + DB dumps
pgdata/
*.dump
*.sql.bak
